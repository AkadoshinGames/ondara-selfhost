# Self-Hosted Ondara Configuration
# Copy this file to .env and fill in the values.
# Runs the merged data-plane (data + economy on one app, port 8080, DB ondara_dataplane).

# Required: Your offline license token from the Ondara Console. This MUST be an RS256
# JWT license (it starts with "eyJ"); it is verified in-process and never phones home.
ONDARA_LICENSE_KEY=eyJ...

# Optional: RSA public key (PEM) used to verify the license JWT. Set this to the
# matching public key you were given for your license; leave empty to use the built-in
# default verification key.
LICENSE_PUBLIC_KEY=

# Required: M2M secret for control plane communication.
# Generate a strong random value, e.g.: openssl rand -base64 32
# There is intentionally NO default — the data-plane refuses to start without it
# wired through, and the management API stays closed when it is empty.
M2M_SECRET=

# Required: Player session JWT keypair (RS256). The data-plane SIGNS and VERIFIES
# player tokens in-process, so set BOTH halves of ONE keypair. These are REQUIRED in
# self-hosted (production) mode — the player surface refuses to boot without a valid
# private key. Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out player_jwt.pem
#   openssl pkey -in player_jwt.pem -pubout -out player_jwt.pub
# Paste the full multi-line PEM contents (compose passes them through verbatim).
PLAYER_JWT_PRIVATE_KEY=
PLAYER_JWT_PUBLIC_KEY=

# Optional: Offline API-key verification (RS256, PUBLIC half only). Set this to the
# Control Plane's API-key public key to verify signed API keys with no round-trip.
# Leave empty to verify keys online against the Control Plane.
API_KEY_PUBLIC_KEY=
# How often (seconds) the local API-key revocation list refreshes. Default 60.
API_KEY_REVOCATION_POLL_SECONDS=60

# Optional: Database password (default: ondara_selfhosted)
DB_PASSWORD=ondara_selfhosted

# Optional: CORS origins for browser-based requests from your console.
# Set this to your console origin. Multiple origins are comma-separated.
# Example: https://console.my-company.com,https://admin.my-company.com
# NOTE: "*" is for local development/testing ONLY — never use it in production.
CORS_ORIGINS=https://console.example.com
